[
  {
    "id": "nest.controllers",
    "name": "Nest: Controllers",
    "description": "Search NestJS controller decorators.",
    "group": "Nest",
    "tags": ["nest", "controller"],
    "order": 10,
    "enabled": true,
    "type": "grep",
    "search": "@Controller",
    "dirs": ["src"],
    "glob": ["*.ts"]
  },
  {
    "id": "nest.services",
    "name": "Nest: Services",
    "description": "Search NestJS injectable providers.",
    "group": "Nest",
    "tags": ["nest", "service", "provider"],
    "order": 20,
    "enabled": true,
    "type": "grep",
    "search": "@Injectable",
    "dirs": ["src"],
    "glob": ["*.ts"]
  },
  {
    "id": "nest.modules",
    "name": "Nest: Modules",
    "description": "Search NestJS module decorators.",
    "group": "Nest",
    "tags": ["nest", "module"],
    "order": 30,
    "enabled": true,
    "type": "grep",
    "search": "@Module",
    "dirs": ["src"],
    "glob": ["*.ts"]
  },
  {
    "id": "nest.dtos",
    "name": "Nest: DTOs",
    "description": "Search DTO class definitions.",
    "group": "DTO",
    "tags": ["nest", "dto", "class"],
    "order": 10,
    "enabled": true,
    "type": "grep",
    "search": "\\bclass\\s+\\w+Dto\\b",
    "regex": true,
    "dirs": ["src"],
    "glob": ["*.ts"]
  },
  {
    "id": "nest.guards",
    "name": "Nest: Guards",
    "description": "Search NestJS guard patterns.",
    "group": "Nest",
    "tags": ["nest", "guard"],
    "order": 40,
    "enabled": true,
    "type": "grep",
    "search": "@Injectable|@UseGuards|CanActivate",
    "regex": true,
    "dirs": ["src"],
    "glob": ["*.guard.ts", "*.ts"]
  },
  {
    "id": "nest.interceptors",
    "name": "Nest: Interceptors",
    "description": "Search NestJS interceptor patterns.",
    "group": "Nest",
    "tags": ["nest", "interceptor"],
    "order": 50,
    "enabled": true,
    "type": "grep",
    "search": "@Injectable|NestInterceptor|@UseInterceptors",
    "regex": true,
    "dirs": ["src"],
    "glob": ["*.interceptor.ts", "*.ts"]
  },
  {
    "id": "nest.decorators",
    "name": "Nest: custom decorators",
    "description": "Search custom decorator definitions.",
    "group": "Nest",
    "tags": ["nest", "decorator", "metadata"],
    "order": 60,
    "enabled": true,
    "type": "grep",
    "search": "\\bexport\\s+(function|const)\\s+\\w+\\s*=.*createParamDecorator|SetMetadata",
    "regex": true,
    "dirs": ["src"],
    "glob": ["*.decorator.ts", "*.ts"]
  },
  {
    "id": "nest.entity_files",
    "name": "Nest: entity files",
    "description": "Find entity files by path.",
    "group": "Data",
    "tags": ["nest", "entity", "files"],
    "order": 10,
    "enabled": true,
    "type": "files_regex",
    "regex": "(^|/)entities?/[^/]+\\.(ts|js)$",
    "dirs": ["src"]
  },
  {
    "id": "nest.module_files",
    "name": "Nest: module files",
    "description": "Find all NestJS module files by path.",
    "group": "Nest",
    "tags": ["nest", "module", "files"],
    "order": 70,
    "enabled": true,
    "type": "files_regex",
    "regex": "\\.module\\.ts$",
    "dirs": ["src"]
  }
]
